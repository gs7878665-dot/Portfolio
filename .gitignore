# ==========================================
# Gaurav Shukla Portfolio - .gitignore
# ==========================================

# Personal/Custom Exclusions
Gaurav Shukla Modern Internship Resume.pdf
output.txt
gaurav.jpg
read_pdf.py
Gaurav_Shukla_Modern_Resume.pdf
*.pdf
*.jpg
*.png
*.webp

# Node.js / Package Managers Dependencies
node_modules/
client/node_modules/
server/node_modules/
jspm_packages/
.pnp
.pnp.js

# Build Outputs & Cache
dist/
client/dist/
build/
out/
.vite/
.eslintcache
.parcel-cache
.cache/

# Debug and System Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local Configuration / Secret Keys / Environments
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env*
server/.env

# Editor & IDE-specific Files
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python Cache & Virtual Environments
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
ENV/
env/

# OS-specific Files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# Temporary files
tmp/
temp/